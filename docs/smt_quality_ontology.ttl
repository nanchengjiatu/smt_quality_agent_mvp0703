    rdf:type smt:ProcessStage ;
    rdfs:label "对位"@zh ;
    rdfs:comment "印刷循环第一段：视觉识别 Fiducial，钢网与 PCB 对位。"@zh .

smt:stage.print_stroke
    rdf:type smt:ProcessStage ;
